# Copy to .aws-deploy.env and fill in local-only AWS deployment values.
# Never commit .aws-deploy.env.

AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=123456789012
AWS_DEPLOY_BUCKET=stravaw-example-private
AWS_DEPLOY_PREFIX=site
AWS_DEPLOY_S3_URI=s3://stravaw-example-private/site
AWS_CLOUDFRONT_DISTRIBUTION_ID=E123EXAMPLE
AWS_CLOUDFRONT_DOMAIN=dexample.cloudfront.net
AWS_CLOUDFRONT_OAC_ID=E123OACEXAMPLE
AWS_BASIC_AUTH_USERNAME=stravaw
AWS_BASIC_AUTH_PASSWORD=replace-me

AWS_CLOUDFRONT_BASIC_AUTH_FUNCTION_NAME=example-basic-auth
AWS_CLOUDFRONT_OAC_NAME=example-s3-oac
AWS_SYNC_QUEUE_NAME=example-sync-events
AWS_SYNC_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/example-sync-events
AWS_SYNC_QUEUE_ARN=arn:aws:sqs:ap-northeast-1:123456789012:example-sync-events
AWS_STRAVA_CLIENT_ID_PARAM=/stravaw/prod/strava/client-id
AWS_STRAVA_CLIENT_SECRET_PARAM=/stravaw/prod/strava/client-secret
AWS_STRAVA_REFRESH_TOKEN_PARAM=/stravaw/prod/strava/refresh-token
AWS_STRAVA_OWNER_ID_PARAM=/stravaw/prod/strava/owner-id
AWS_STRAVA_VERIFY_TOKEN_PARAM=/stravaw/prod/strava/webhook-verify-token
AWS_MANUAL_REFRESH_TOKEN_PARAM=/stravaw/prod/manual-refresh-token
AWS_SYNC_STATE_PARAM=/stravaw/prod/sync-state
AWS_LAMBDA_TRIGGER_ROLE_NAME=example-trigger-lambda-role
AWS_LAMBDA_WORKER_ROLE_NAME=example-worker-lambda-role
AWS_LAMBDA_WORKER_NAME=example-sync-worker
AWS_LAMBDA_WEBHOOK_NAME=example-webhook-receiver
AWS_LAMBDA_MANUAL_NAME=example-manual-refresh
AWS_STRAVA_VERIFY_TOKEN=replace-me
AWS_MANUAL_REFRESH_TOKEN=replace-me
AWS_STRAVA_OWNER_ID=123456789
AWS_WEBHOOK_FUNCTION_URL=https://example.lambda-url.ap-northeast-1.on.aws/
AWS_MANUAL_FUNCTION_URL=https://example.lambda-url.ap-northeast-1.on.aws/
AWS_STRAVA_WEBHOOK_SUBSCRIPTION_ID=123456
